# RPC URL resolution: getRpcUrl(chainId) returns RPC_<chainId> if set,
# otherwise `${RPC_PREFIX_URL}/${chainId}`. Set RPC_PREFIX_URL for the
# common case; set per-chain RPC_<chainId> only when a chain needs a
# different provider.
RPC_PREFIX_URL=
# RPC_4217=https://rpc.tempo.xyz   # example override

FAILED_EVENT_DESTINATION_ARN=

UNISWAPX_SERVICE_URL=
URA_SERVICE_URL=
GPA_SERVICE_URL=
COSIGNER_ADDRESS=

UNISWAP_API=
TEST_WALLET_PK=
TEST_FILLER_PK=

LABS_COSIGNER=
LABS_PRIORITY_COSIGNER=
